---
import "../index.css";
import getfadedLogo from "@/assets/getfaded-logo.png";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href={getfadedLogo.src} />
    <link rel="apple-touch-icon" href={getfadedLogo.src} />
    <title>Page Not Found</title>
  </head>
  <body>
    <main class="flex min-h-screen items-center justify-center bg-muted">
      <section class="text-center">
        <h1 class="mb-4 text-4xl font-bold">404</h1>
        <p class="mb-4 text-xl text-muted-foreground">Oops! Page not found</p>
        <a href="/" class="text-primary underline hover:text-primary/90">
          Return to Home
        </a>
      </section>
    </main>
  </body>
</html>
