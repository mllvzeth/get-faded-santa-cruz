---
import "../index.css";
import { Image } from "astro:assets";
import { MapPin, Phone, Clock, Instagram, Facebook, Menu, Star, Play } from "lucide-react";
import { buttonVariants } from "@/components/ui/button";
import heroImage from "@/assets/hero-barbershop.jpg";
import styleFade from "@/assets/style-fade.jpg";
import styleBeard from "@/assets/style-beard.jpg";
import styleClassic from "@/assets/style-classic.jpg";
import barberRed from "@/assets/barber-red.jpg";
import barberPinks from "@/assets/barber-pinks.jpg";
import barberAnthony from "@/assets/barber-anthony.jpg";
import barberAndreas from "@/assets/barber-andreas.jpg";
import barberOscar from "@/assets/barber-oscar.jpg";
import barberRicky from "@/assets/barber-ricky.jpg";
import barberJose from "@/assets/barber-jose.jpg";
import primary20260325Anthony from "@/assets/20260325_anthony.jpg";
import primary20260325Pinks from "@/assets/20260325_pink.jpg";
import primary20260325Andreas from "@/assets/20260325_andres.jpg";
import primary20260325Oscar from "@/assets/20260325_oscar.jpg";
import primary20260325Ricky from "@/assets/20260325_rick.jpg";
import primary20260325Jose from "@/assets/20260325_jose.jpg";
import getfadedLogo from "@/assets/getfaded-logo.png";
import ctaShopBg from "@/assets/getfaded-santa-cruz-fuck-ice.jpg";

// Today's gallery assets (Apr 12) — iPhone portrait photos + .mov videos
import img7600 from "@/assets/IMG_7600.png";
import img7601 from "@/assets/IMG_7601.png";
import img7602 from "@/assets/IMG_7602.png";
import img7603 from "@/assets/IMG_7603.png";
import img7604 from "@/assets/IMG_7604.png";
import img7606 from "@/assets/IMG_7606.png";
import img7607 from "@/assets/IMG_7607.png";
import img7609 from "@/assets/IMG_7609.png";
import img7610 from "@/assets/IMG_7610.png";
import img7611 from "@/assets/IMG_7611.png";
import img7612 from "@/assets/IMG_7612.png";
import img7138 from "@/assets/IMG_7138.png";
import img7142 from "@/assets/IMG_7142.png";
import img7151 from "@/assets/IMG_7151.png";
import dsc04250 from "@/assets/DSC04250.png";
import workVideo1 from "@/assets/1a8f648c775343d0a07fc5237079222c.mp4?url";
import workVideo2 from "@/assets/61eccd3253744c19ab1c4f3bcdd30b99.mp4?url";
import workVideo3 from "@/assets/234ab5a506e74eb6a025b7c53614ccc4.mp4?url";
import heroVideoMp4 from "@/assets/hero-video.mp4?url";
import heroVideoWebm from "@/assets/hero-video.webm?url";

export const prerender = true;

const businessName = "Get Faded Barbershop";
const businessTagline = "Cuts • Culture • Community";
const businessResetLine = `Not just a cut \n you get reset.`;
const aboutCopy =
    "Great Cuts. Total Comfort.\nNear downtown Santa Cruz; chill, relax, be yourself.\nWalk out fresh with an excellent cut.";
const mainBookingUrl = "https://getsquire.com/discover/barbershop/get-faded-barbershop-santa-cruz";
const businessAddress = "907 Cedar St, Santa Cruz, CA 95060";
const businessPhone = "(831) 600-8958";
const callUrl = "tel:+18316008958";
const directionsUrl = "https://www.google.com/maps/dir/?api=1&destination=Get%20Faded%20Barbershop,%201007%20Cedar%20St,%20Santa%20Cruz,%20CA%2095060";
const googleReviewsUrl = "https://www.google.com/search?q=get%20faded%20sc#lrd=0x808e4028b1890a8b:0x2762688a2815118c,1,,,,";
const yelpReviewsUrl = "https://www.yelp.com/biz/get-faded-barbershop-santa-cruz-3?adjust_creative=duckduckgo&hrid=qBGdK3fe0gR5AWx9GZhWlw";
const facebookSocialUrl = "https://www.facebook.com/getfadedsc/";
const yelpSocialUrl = "https://www.yelp.com/biz/get-faded-barbershop-santa-cruz-3";
const instagramSocialUrl = "https://www.instagram.com/get__faded/";

const services = [
    {
        name: "Haircuts",
        price: "$48+",
        description: "Standard cuts ($48+), Get Faded Special ($158) & house calls ($300)",
        duration: "30 min – 3 hrs",
    },
    {
         name: "Hot Towel Razor Shave",
         price: "$48+",
         description: "Premium straight razor shave with hot towel treatment",
	duration: "15 – 30 min",
    },
    {
        name: "Modern Hairstyles",
        price: "$58+",
        description: "Trendy cuts & styles for the modern look",
        duration: "30 min – 1 hr",
    },
    {
        name: "Sissor Haircut",
        price: "$68+",
        description: "Classic precision cuts with expert technique",
        duration: "30 min – 1 hr",
    },
    // {
    //     name: "Add-Ons",
    //     price: "$10 – $13",
    //     description: "Shampoo, head wash & design add-ons",
    //     duration: "15 min",
    // },
];

const barbers = [
    { name: "Red Vasquez", primaryImage: barberRed.src, revealImage: barberRed.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/red-vasquez/services", cropClass: "object-[42%_26%]" },
    { name: "Pinks", primaryImage: primary20260325Pinks.src, revealImage: barberPinks.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/pinks-cash-preferred/services", cropClass: "object-[50%_22%]" },
    { name: "Anthony Negrete", primaryImage: primary20260325Anthony.src, revealImage: barberAnthony.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/anthony-negrete/services", cropClass: "object-[50%_24%]" },
    { name: "Andreas Olmedo", primaryImage: primary20260325Andreas.src, revealImage: barberAndreas.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/andreas-olmedo/services", cropClass: "object-[42%_24%]" },
    { name: "Oscar Rameno", primaryImage: primary20260325Oscar.src, revealImage: barberOscar.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/oscar-rameno/services", cropClass: "object-[50%_24%]" },
    { name: "Ricky Cutz", primaryImage: primary20260325Ricky.src, revealImage: barberRicky.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/ricky-cutz/services", cropClass: "object-[58%_30%]" },
    { name: "Jose Moya", primaryImage: primary20260325Jose.src, revealImage: barberJose.src, bookingUrl: "https://getsquire.com/booking/book/get-faded-barbershop-santa-cruz/barber/jose-moya/services", cropClass: "object-[50%_24%]" },
];

const galleryImages = [
    { src: styleFade, alt: "Classic Fade", label: "Fade" },
    { src: styleBeard, alt: "Beard Grooming", label: "Beard" },
    { src: styleClassic, alt: "Classic Style", label: "Classic" },
    { src: heroImage, alt: "Premium Cut", label: "Premium" },
    { src: styleFade, alt: "Signature Look", label: "Signature" },
    { src: styleBeard, alt: "Clean Shave", label: "Clean" },
];

const workPhotos = [
    img7600, img7601, img7602, img7603, img7604, img7606, img7607,
    img7609, img7610, img7611, img7612, img7138, img7142, img7151, dsc04250,
];
const workVideos = [workVideo1 as string, workVideo2 as string, workVideo3 as string];

const reviews = [
//     { name: "Michael T.", text: "Best barbershop in town! Been coming here for 2 years.", rating: 5 },
//     { name: "David R.", text: "Marcus always hooks me up with the perfect fade.", rating: 5 },
//     { name: "Chris L.", text: "Professional service, great atmosphere. Highly recommend!", rating: 5 },
];
---
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href={getfadedLogo.src} />
        <link rel="apple-touch-icon" href={getfadedLogo.src} />
        <title>Get Faded Barbershop</title>
    </head>
    <body>
        <div class="min-h-screen bg-background">
            <nav class="fixed top-0 left-0 right-0 z-50 bg-background/95 backdrop-blur-lg border-b border-border/50">
                <div class="container flex items-center justify-between h-16 md:h-20">
                    <a href="#" class="flex items-center">
                        <Image
                            src={getfadedLogo}
                            alt={businessName}
                            loading="eager"
                            fetchpriority="high"
                            width={144}
                            height={56}
                            class="h-12 md:h-14 w-auto"
                        />
                    </a>

                    <div class="hidden md:flex items-center gap-8">
                        <a href="#team" class="text-sm text-muted-foreground hover:text-primary transition-colors uppercase tracking-wider">Barbers</a>
                        <a href="#services" class="text-sm text-muted-foreground hover:text-primary transition-colors uppercase tracking-wider">Services</a>
                        <a href="#reviews" class="text-sm text-muted-foreground hover:text-primary transition-colors uppercase tracking-wider">Reviews</a>
                        <a href="#contact" class="text-sm text-muted-foreground hover:text-primary transition-colors uppercase tracking-wider">Contact</a>
                    </div>
                    <a
                        href={mainBookingUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={buttonVariants({ variant: "hero", size: "sm", className: "hidden md:inline-flex uppercase tracking-wider button-shimmer shimmer-delay-1" })}
                    >
                        Book Now
                    </a>

                    <details class="md:hidden relative" data-mobile-menu>
                        <summary class="list-none cursor-pointer text-foreground p-2 [&::-webkit-details-marker]:hidden">
                            <Menu className="w-6 h-6" />
                        </summary>
                        <div class="absolute right-0 top-14 min-w-52 rounded-lg border border-border bg-background p-4 shadow-xl animate-menu-open" data-mobile-menu-panel>
                            <div class="flex flex-col gap-4">
                                <a href="#team" class="text-foreground py-1 uppercase tracking-wider" data-mobile-menu-item>Barbers</a>
                                <a href="#services" class="text-foreground py-1 uppercase tracking-wider" data-mobile-menu-item>Services</a>
                                <a href="#reviews" class="text-foreground py-1 uppercase tracking-wider" data-mobile-menu-item>Reviews</a>
                                <a href="#contact" class="text-foreground py-1 uppercase tracking-wider" data-mobile-menu-item>Contact</a>
                                <a
                                    href={mainBookingUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class={buttonVariants({ variant: "hero", className: "w-full uppercase tracking-wider button-shimmer shimmer-delay-2" })}
                                    data-mobile-menu-item
                                >
                                    Book Now
                                </a>
                            </div>
                        </div>
                    </details>
                </div>
            </nav>

            <section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
                <div class="absolute inset-0 bg-black">
                    <video
                        autoplay
                        muted
                        loop
                        playsinline
                        preload="auto"
                        disablepictureinpicture
                        class="absolute inset-0 w-full h-full object-cover"
                        data-autoplay
                    >
                        <source src={heroVideoWebm as string} type="video/webm" />
                        <source src={heroVideoMp4 as string} type="video/mp4" />
                    </video>
                    <div class="absolute inset-0 bg-black/30"></div>
                    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/35 to-black/60"></div>
                </div>

                <div class="container relative z-10 text-center py-20">
                    <div class="max-w-3xl mx-auto">
                        <h1 class="font-display text-[clamp(2.75rem,10vw,4.5rem)] font-bold leading-tight mb-4 animate-fade-up opacity-0 text-foreground [text-shadow:0_3px_14px_rgba(0,0,0,0.65)]">
                            Cuts • Culture • <span class="text-primary glow-gold">Community</span>
                        </h1>
                            <p class="text-xl md:text-2xl text-foreground/95 mb-2 max-w-sm md:max-w-md mx-auto animate-fade-up opacity-0 delay-100 uppercase tracking-widest [text-shadow:0_2px_10px_rgba(0,0,0,0.6)] text-center">
                                {businessResetLine}
                            </p>
                            <p class="text-lg text-foreground/85 mb-10 max-w-sm md:max-w-md mx-auto animate-fade-up opacity-0 delay-200 [text-shadow:0_1px_8px_rgba(0,0,0,0.55)]">
                                {aboutCopy}
                            </p>
                        <div class="flex flex-col items-center gap-4">
                            <div class="animate-fade-up opacity-0 delay-300">
                                <a
                                    href={mainBookingUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class={buttonVariants({ variant: "hero", size: "lg", className: "uppercase tracking-wider text-lg px-10 py-6 min-w-[160px] button-shimmer shimmer-delay-3" })}
                                >
                                    Book Now
                                </a>
                            </div>
                            <a
                                href={directionsUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class={buttonVariants({ variant: "secondary", size: "lg", className: "animate-fade-up opacity-0 delay-400 uppercase tracking-wider text-lg px-10 py-6 min-w-[160px]" })}
                            >
                                Directions
                            </a>
                            <a
                                href={callUrl}
                                class={buttonVariants({ variant: "secondary", size: "lg", className: "animate-fade-up opacity-0 delay-500 uppercase tracking-wider text-lg px-10 py-6 min-w-[160px]" })}
                            >
                                Call
                            </a>
                        </div>
                    </div>

                    <div class="absolute bottom-6 left-1/2 -translate-x-1/2">
                        <div class="animate-bounce">
                            <div class="w-6 h-10 border-2 border-primary rounded-full flex justify-center pt-2 shadow-[0_0_18px_hsl(var(--primary)/0.55)]">
                                <div class="w-1.5 h-3 bg-primary rounded-full animate-pulse shadow-[0_0_10px_hsl(var(--primary)/0.8)]"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section id="team" class="py-20 md:py-28 bg-charcoal-light">
                <div class="container">
                    <div class="text-center mb-12">
                        <span class="text-primary text-sm font-medium tracking-[0.3em] uppercase">Our Team</span>
                        <h2 class="font-display text-3xl md:text-5xl font-bold mt-4 uppercase tracking-wide">
                            Meet Our <span class="text-gradient">Barbers</span>
                        </h2>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 md:gap-8">
                        {barbers.map((barber, index) => (
                        <a
                            href={barber.bookingUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group text-center reveal-soft-rise"
                            data-reveal
                            style={`animation-delay: ${index * 100}ms`}
                        >
                            <div class="relative w-28 h-28 sm:w-32 sm:h-32 md:w-36 md:h-36 mx-auto mb-4 overflow-hidden rounded-full bg-black">
                                <div class="absolute inset-0 z-10 rounded-full border-2 border-primary/30 group-hover:border-primary group-hover:shadow-gold transition-all duration-300"></div>
                                {barber.primaryImage && (
                                    <img
                                        src={barber.primaryImage}
                                        alt={`${barber.name} portrait`}
                                        loading="lazy"
                                        width="144"
                                        height="144"
                                        class={`absolute inset-0 w-full h-full object-cover ${barber.cropClass} scale-[1.25] opacity-100 group-hover:opacity-0 transform-gpu transition-all duration-500 rounded-full`}
                                    />
                                )}
                                <img
                                    src={barber.revealImage}
                                    alt={`${barber.name} alternate portrait`}
                                    loading="lazy"
                                    width="144"
                                    height="144"
                                    class={`absolute inset-0 w-full h-full object-cover ${barber.cropClass} scale-[1.25] opacity-0 group-hover:opacity-100 group-hover:scale-[1.15] transform-gpu transition-all duration-500 rounded-full`}
                                />
                            </div>
                            <h3 class="font-display text-lg md:text-xl font-semibold text-foreground group-hover:text-primary transition-colors">{barber.name}</h3>
                            <p class="text-xs text-primary uppercase tracking-wider mt-1">Book Now</p>
                        </a>
                        ))}
                    </div>
                </div>
            </section>

            <section id="services" class="py-20 md:py-32">
                <div class="container">
                    <div class="text-center mb-16">
                        <span class="text-primary text-sm font-medium tracking-widest uppercase">Our Services</span>
                        <h2 class="font-display text-4xl md:text-5xl font-bold mt-4">
                            Premium <span class="text-gradient">Grooming</span>
                        </h2>
                    </div>

                    <div class="grid gap-4 md:gap-6 max-w-2xl mx-auto">
                        {services.map((service, index) => (
                        <div
                            class="group relative p-6 rounded-2xl bg-gradient-card border border-border/50 hover:border-primary/30 transition-all duration-300 hover:shadow-gold reveal-soft-slide"
                            data-reveal
                            style={`animation-delay: ${index * 100}ms`}
                        >
                            <div class="flex items-center justify-between">
                                <div class="flex-1">
                                    <div class="flex flex-col gap-1 mb-2 sm:flex-row sm:items-center sm:gap-3">
                                        <h3 class="font-display text-xl font-semibold text-foreground group-hover:text-gradient transition-colors">
                                            {service.name}
                                        </h3>
                                        <span class="self-start text-xs text-muted-foreground px-2 py-1 rounded-full bg-secondary sm:self-auto">
                                            {service.duration}
                                        </span>
                                    </div>
                                    <p class="text-muted-foreground text-sm">{service.description}</p>
                                </div>
                                <div class="text-right">
                                    <div class="font-display text-2xl font-bold text-primary">{service.price}</div>
                                </div>
                            </div>
                            <div class="absolute inset-0 rounded-2xl bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
                        </div>
                        ))}
                    </div>

                    <div class="text-center mt-12">
                        <a href={mainBookingUrl} target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "hero", size: "lg", className: "uppercase tracking-wider" })}>Book Appointment</a>
                    </div>
                </div>
            </section>

            <section id="gallery" class="py-20 md:py-28 hidden">
                <div class="container">
                    <div class="text-center mb-12">
                        <span class="text-primary text-sm font-medium tracking-[0.3em] uppercase">Our Work</span>
                        <h2 class="font-display text-3xl md:text-5xl font-bold mt-4 uppercase tracking-wide">
                            <span class="text-gradient">Videos</span>
                        </h2>
                    </div>

                    <div class="relative aspect-video max-w-4xl mx-auto rounded-xl overflow-hidden mb-8 group cursor-pointer">
                        <Image
                            src={heroImage}
                            alt="Watch our work"
                            loading="lazy"
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-background/40 flex items-center justify-center group-hover:bg-background/30 transition-colors">
                            <div class="w-20 h-20 rounded-full bg-primary flex items-center justify-center shadow-gold group-hover:scale-110 transition-transform">
                                <Play className="w-8 h-8 text-primary-foreground ml-1" fill="currentColor" />
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 md:gap-4">
                        {galleryImages.map((image) => (
                        <div class="group relative aspect-square rounded-xl overflow-hidden">
                            <Image
                                src={image.src}
                                alt={image.alt}
                                loading="lazy"
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <Play className="w-10 h-10 text-foreground" />
                            </div>
                        </div>
                        ))}
                    </div>
                </div>
            </section>

            <section id="reviews" class="py-20 md:py-28 bg-charcoal-light">
                <div class="container">
                    <div class="text-center mb-12">
                        <span class="text-primary text-sm font-medium tracking-[0.3em] uppercase">Testimonials</span>
                        <h2 class="font-display text-3xl md:text-5xl font-bold mt-4 uppercase tracking-wide">
                            Client <span class="text-shimmer-gold shimmer-delay-1" data-text="Reviews">Reviews</span>
                        </h2>
                    </div>

                    <div class="grid gap-6 md:grid-cols-3 max-w-5xl mx-auto mb-12 hidden">
                        {reviews.map((review) => (
                        <div class="p-6 rounded-xl bg-gradient-card border border-border/50 hover:border-primary/30 transition-all">
                            <div class="flex gap-1 mb-4">
                                {Array.from({ length: review.rating }).map(() => (
                                <Star className="w-5 h-5 text-primary fill-primary" />
                                ))}
                            </div>
                            <p class="text-muted-foreground mb-4 italic">"{review.text}"</p>
                            <p class="font-semibold text-foreground">{review.name}</p>
                        </div>
                        ))}
                    </div>

                    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10">
                        <a href={googleReviewsUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-lg bg-secondary hover:bg-secondary/80 transition-colors">
                            <span class="text-2xl">G</span>
                            <span class="text-sm font-semibold">Google</span>
                        </a>
                        <a href={yelpReviewsUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-lg bg-secondary hover:bg-secondary/80 transition-colors">
                            <span class="text-2xl">Y</span>
                            <span class="text-sm font-semibold">Yelp</span>
                        </a>
                        <a href={facebookSocialUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-lg bg-secondary hover:bg-secondary/80 transition-colors">
                            <Facebook className="w-6 h-6" />
                            <span class="text-sm font-semibold">Facebook</span>
                        </a>
                    </div>
                </div>
            </section>

            <section class="py-20 md:py-28 relative overflow-hidden">
                <div class="absolute inset-0">
                    <Image
                        src={ctaShopBg}
                        alt="Get Faded Barbershop Santa Cruz"
                        loading="lazy"
                        class="w-full h-full object-cover object-[center_top]"
                    />
                    <div class="absolute inset-0 bg-black/60"></div>
                </div>
                <div class="container relative">
                    <div class="max-w-2xl mx-auto text-center">
                        <h2 class="font-display text-3xl md:text-5xl font-bold mb-6 uppercase tracking-wide">
                            {businessName}
                        </h2>
                        <p class="text-lg text-muted-foreground mb-8">
                            {businessTagline} | {businessResetLine}
                        </p>
                        <a href={mainBookingUrl} target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "hero", size: "lg", className: "uppercase tracking-wider px-10" })}>Book Now</a>
                    </div>
                </div>
            </section>

            <!-- ── Fresh Cuts Gallery ─────────────────────────────── -->
            <section id="work" class="py-20 md:py-28 bg-background">
                <div class="container mb-10">
                    <div class="reveal-soft-rise flex items-end justify-between flex-wrap gap-4" data-reveal>
                        <div>
                            <span class="text-primary text-sm font-medium tracking-[0.3em] uppercase">Our Work</span>
                            <h2 class="font-display text-3xl md:text-5xl font-bold mt-4 uppercase tracking-wide">
                                Fresh <span class="text-gradient">Cuts</span>
                            </h2>
                        </div>
                        <a
                            href="https://www.instagram.com/get__faded"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 text-muted-foreground hover:text-primary transition-colors text-sm font-medium uppercase tracking-wider pb-1"
                        >
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                                <circle cx="12" cy="12" r="4.5"/>
                                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                            </svg>
                            @get__faded
                        </a>
                    </div>
                </div>

                <!-- Photo reel — auto-scrolls, pauses on hover, taps open Instagram -->
                <div id="gallery-reel-wrapper" class="relative overflow-hidden">
                    <!-- Gradient edges — hint that content continues -->
                    <div class="absolute left-0 inset-y-0 w-12 md:w-20 z-10 pointer-events-none"
                         style="background:linear-gradient(to right,hsl(var(--background)),transparent)"></div>
                    <div class="absolute right-0 inset-y-0 w-12 md:w-20 z-10 pointer-events-none"
                         style="background:linear-gradient(to left,hsl(var(--background)),transparent)"></div>

                    <!-- One-shot swipe hint badge -->
                    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 pointer-events-none gallery-swipe-hint">
                        <div class="flex items-center gap-1.5 bg-black/70 backdrop-blur-sm border border-white/15 rounded-full px-3 py-1.5">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="hsl(var(--primary))" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="4 2 8 6 4 10"/>
                            </svg>
                            <span class="text-[10px] text-white/70 uppercase tracking-widest font-medium">Swipe</span>
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="hsl(var(--primary))" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="4 2 8 6 4 10"/>
                            </svg>
                        </div>
                    </div>

                    <!-- The scrolling strip — photos duplicated for seamless loop -->
                    <div id="gallery-reel" class="gallery-reel flex gap-3 pb-5 pt-3 px-4">
                        {[...workPhotos, ...workPhotos].map((photo, i) => (
                            <a
                                href="https://www.instagram.com/get__faded"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex-shrink-0 group relative overflow-hidden rounded-2xl border border-white/10 hover:border-primary/60 transition-all duration-300 hover:shadow-[0_0_28px_hsl(var(--primary)/0.35)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
                                style="width:min(calc(45vw - 0.75rem),175px);aspect-ratio:9/16"
                                aria-label="View on Instagram"
                            >
                                <img
                                    src={photo.src}
                                    alt=""
                                    loading="lazy"
                                    width={photo.width}
                                    height={photo.height}
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 pointer-events-none"
                                />
                                <!-- Instagram hover overlay -->
                                <div class="absolute inset-0 bg-black/55 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center gap-2 pointer-events-none">
                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                                        <circle cx="12" cy="12" r="4.5"/>
                                        <circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none"/>
                                    </svg>
                                    <span class="text-[9px] text-white/80 uppercase tracking-[0.2em] font-medium">@get__faded</span>
                                </div>
                            </a>
                        ))}
                    </div>
                </div>

                <!-- Videos — portrait cards -->
                <div class="container mt-5">
                    <div class="flex sm:grid sm:grid-cols-3 gap-3 overflow-x-auto sm:overflow-visible [scrollbar-width:none] [&::-webkit-scrollbar]:hidden pb-2 sm:pb-0">
                        {workVideos.map((videoSrc, i) => (
                            <div
                                class="w-[70vw] max-w-[260px] flex-shrink-0 sm:w-auto sm:max-w-none relative overflow-hidden rounded-2xl border border-white/10 hover:border-primary/40 transition-all duration-300 hover:shadow-[0_0_22px_hsl(var(--primary)/0.25)]"
                                style="aspect-ratio:9/16; min-width:0"
                            >
                                <video
                                    autoplay
                                    muted
                                    loop
                                    playsinline
                                    preload="auto"
                                    disablepictureinpicture
                                    class="w-full h-full object-cover"
                                    data-autoplay
                                >
                                    <source src={videoSrc} type="video/mp4" />
                                </video>
                                <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent pointer-events-none"></div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>

            <section id="contact" class="py-20 md:py-28 bg-charcoal-light">
                <div class="container">
                    <div class="grid md:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
                        <div>
                            <span class="text-primary text-sm font-medium tracking-[0.3em] uppercase">Visit Us</span>
                            <h2 class="font-display text-3xl md:text-4xl font-bold mt-4 mb-8 uppercase">
                                Our <span class="text-gradient">Location</span>
                            </h2>
                            <div class="space-y-4 text-muted-foreground">
                                <div class="flex items-center gap-4">
                                    <MapPin className="w-6 h-6 text-primary flex-shrink-0" />
                                    <span>{businessAddress}</span>
                                </div>
                                <div class="flex items-center gap-4">
                                    <Phone className="w-6 h-6 text-primary flex-shrink-0" />
                                    <span>{businessPhone}</span>
                                </div>
                                <div class="flex items-center gap-4">
                                    <Clock className="w-6 h-6 text-primary flex-shrink-0" />
                                    <div>
                                        <p>Mon - Fri: 9AM - 6PM</p>
                                        <p>Sat: 9AM - 4PM</p>
                                        <p>Sun: 9AM - 2PM</p>
                                    </div>
                                </div>
                            </div>
                            <a
                                href={directionsUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class={buttonVariants({ variant: "hero", size: "lg", className: "mt-8 uppercase tracking-wider" })}
                            >
                                Get Directions
                            </a>
                        </div>
                        <div class="aspect-video rounded-xl overflow-hidden bg-secondary">
                            <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                                <MapPin className="w-16 h-16 text-primary/30" />
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <footer class="py-12 border-t border-border/50">
                <div class="container">
                    <div class="flex flex-col items-center gap-8">
                        <Image src={getfadedLogo} alt={businessName} loading="lazy" width={164} height={64} class="h-16 w-auto" />

                        <div class="flex items-center gap-6">
                            <a href={instagramSocialUrl} target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-secondary hover:bg-primary hover:text-primary-foreground transition-colors">
                                <Instagram className="w-5 h-5" />
                            </a>
                            <a href={facebookSocialUrl} target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-secondary hover:bg-primary hover:text-primary-foreground transition-colors">
                                <Facebook className="w-5 h-5" />
                            </a>
                            <a href={yelpSocialUrl} target="_blank" rel="noopener noreferrer" aria-label="Yelp" class="p-3 rounded-full bg-secondary hover:bg-primary hover:text-primary-foreground transition-colors text-sm font-semibold">
                                Y
                            </a>
                        </div>

                        <div class="text-center">
                            <p class="text-sm text-muted-foreground">
                                © {businessName}. All rights reserved.
                            </p>
                            <p class="text-xs text-muted-foreground/50 mt-2">
                                {businessAddress}
                            </p>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
        <script>
        const initializeRevealAnimations = () => {
            const revealElements = Array.from(document.querySelectorAll("[data-reveal]"));

            if (revealElements.length === 0) {
                return;
            }

            const revealElement = (element) => {
                element.classList.add("reveal-visible");
            };

            if (!("IntersectionObserver" in window)) {
                revealElements.forEach(revealElement);
                return;
            }

            const revealObserver = new IntersectionObserver(
                (entries, observer) => {
                    entries.forEach((entry) => {
                        if (!entry.isIntersecting) {
                            return;
                        }

                        revealElement(entry.target);
                        observer.unobserve(entry.target);
                    });
                },
                {
                    threshold: 0.08,
                    rootMargin: "0px 0px -5% 0px",
                },
            );

            revealElements.forEach((element) => {
                const rect = element.getBoundingClientRect();
                const isAlreadyVisible = rect.top < window.innerHeight * 0.95 && rect.bottom > 0;

                if (isAlreadyVisible) {
                    revealElement(element);
                    return;
                }

                revealObserver.observe(element);
            });
        };

        const initializeMobileMenuAnimations = () => {
            const mobileMenu = document.querySelector("[data-mobile-menu]");
            const menuPanel = document.querySelector("[data-mobile-menu-panel]");

            if (!mobileMenu || !menuPanel) {
                return;
            }

            let closeTimeout;
            let autoScrollTimeout;
            let isAutoScrolling = false;
            const closeDurationMs = 180;
            const autoScrollStopDelayMs = 160;

            /**
             * Keeps the auto-scroll window alive while scrolling continues.
             */
            const refreshAutoScrollTracking = () => {
                if (!isAutoScrolling) {
                    return;
                }

                if (autoScrollTimeout) {
                    window.clearTimeout(autoScrollTimeout);
                }

                autoScrollTimeout = window.setTimeout(() => {
                    isAutoScrolling = false;
                }, autoScrollStopDelayMs);
            };

            /**
             * Marks anchor-based scrolling so the menu can reopen mid-scroll.
             */
            const startAutoScrollTracking = () => {
                isAutoScrolling = true;
                refreshAutoScrollTracking();
            };

            const closeMenu = () => {
                if (!mobileMenu.hasAttribute("open")) {
                    return;
                }

                if (closeTimeout) {
                    window.clearTimeout(closeTimeout);
                }

                menuPanel.classList.remove("animate-menu-open");
                menuPanel.classList.add("animate-menu-close");

                closeTimeout = window.setTimeout(() => {
                    mobileMenu.removeAttribute("open");
                    menuPanel.classList.remove("animate-menu-close");
                    menuPanel.classList.add("animate-menu-open");
                }, closeDurationMs);
            };

            mobileMenu.addEventListener("toggle", () => {
                if (!mobileMenu.hasAttribute("open")) {
                    return;
                }

                if (closeTimeout) {
                    window.clearTimeout(closeTimeout);
                }

                menuPanel.classList.remove("animate-menu-close");
                menuPanel.classList.add("animate-menu-open");
            });

            const menuSummary = mobileMenu.querySelector("summary");
            menuSummary?.addEventListener("click", (event) => {
                if (!mobileMenu.hasAttribute("open")) {
                    return;
                }

                event.preventDefault();
                closeMenu();
            });

            const menuItems = mobileMenu.querySelectorAll("[data-mobile-menu-item]");
            menuItems.forEach((menuItem) => {
                menuItem.addEventListener("click", () => {
                    const href = menuItem.getAttribute("href") ?? "";

                    if (href.startsWith("#")) {
                        startAutoScrollTracking();
                    }

                    closeMenu();
                });
            });
            const handleOutsideClick = (event) => {
                if (!mobileMenu.hasAttribute("open")) {
                    return;
                }

                if (!(event.target instanceof Node)) {
                    return;
                }

                if (mobileMenu.contains(event.target)) {
                    return;
                }

                closeMenu();
            };

            document.addEventListener("click", handleOutsideClick);

            window.addEventListener(
                "scroll",
                () => {
                    if (isAutoScrolling) {
                        refreshAutoScrollTracking();
                        return;
                    }
                    closeMenu();
                },
                { passive: true },
            );
        };

        const initGallery = () => {
            // Gallery reel is CSS-animated; no JS needed for auto-scroll.
            // On touch devices, briefly pause after a tap so the link registers.
            const reel = document.getElementById("gallery-reel");
            if (reel) {
                reel.addEventListener("touchstart", () => {
                    reel.style.animationPlayState = "paused";
                }, { passive: true });

                reel.addEventListener("touchend", () => {
                    setTimeout(() => { reel.style.animationPlayState = ""; }, 1200);
                }, { passive: true });
            }
        };

        // Force-play all muted autoplay videos — required on many mobile browsers
        // that silently ignore the `autoplay` attribute until .play() is called.
        const initVideoAutoplay = () => {
            const videos = Array.from(
                document.querySelectorAll<HTMLVideoElement>("video[data-autoplay]")
            );

            const tryPlay = (video: HTMLVideoElement) => {
                if (video.paused) {
                    video.play().catch(() => {
                        // Retry once on first user interaction (covers strict autoplay policies)
                        const retry = () => { video.play().catch(() => {}); };
                        document.addEventListener("touchstart", retry, { once: true, passive: true });
                        document.addEventListener("click", retry, { once: true });
                    });
                }
            };

            // Attempt immediately for already-visible videos
            videos.forEach(tryPlay);

            // Also watch via IntersectionObserver so off-screen videos play when scrolled to
            if ("IntersectionObserver" in window) {
                const obs = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) tryPlay(entry.target as HTMLVideoElement);
                        });
                    },
                    { threshold: 0.25 }
                );
                videos.forEach((v) => obs.observe(v));
            }
        };

        if (document.readyState === "loading") {
            document.addEventListener(
                "DOMContentLoaded",
                () => {
                    initializeRevealAnimations();
                    initializeMobileMenuAnimations();
                    initGallery();
                    initVideoAutoplay();
                },
                { once: true },
            );
        } else {
            initializeRevealAnimations();
            initializeMobileMenuAnimations();
            initGallery();
            initVideoAutoplay();
        }
        </script>
    </body>
</html>
